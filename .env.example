# ─────────────────────────────────────────────────────────
# Variables de entorno para JMS Valoraciones
# Copia este fichero como .env o ponlas directamente
# en Easypanel → Service → Environment Variables
# ─────────────────────────────────────────────────────────

# SMTP – Infomaniak
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USER=jorge.martinez@geotasalia.es
SMTP_PASS=TU_CONTRASEÑA_AQUI

# Email donde llegarán los mensajes del formulario
# (puede ser el mismo SMTP_USER u otro)
SMTP_TO=jorge.martinez@geotasalia.es

# Dominio público (usado en auto-respuesta)
NEXT_PUBLIC_SITE_URL=https://www.geotasalia.es
